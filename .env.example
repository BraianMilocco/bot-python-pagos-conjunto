# Telegram
BOT_TOKEN=your_telegram_bot_token_here
BRAIAN_TELEGRAM_ID=123456789
CONSTANZA_TELEGRAM_ID=987654321

# PostgreSQL (used by docker-compose and the bot)
POSTGRES_DB=finanzas
POSTGRES_USER=botuser
POSTGRES_PASSWORD=changeme

# Connection URL built from the values above.
# In Docker: host is "db" (the service name in docker-compose).
# Locally: use "localhost" instead.
DATABASE_URL=postgresql://botuser:changeme@db:5432/finanzas
